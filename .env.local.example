# =====================================================================

# Google Places reviews
# Place ID already has a production-safe default in app config. Add the
# server-only API key in Vercel to switch the review cards from fallback
# mode to live Google rating and reviews.
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY
# Optional override:
NEXT_PUBLIC_GOOGLE_PLACE_ID=ChIJ0WlgzNWFHjkRNMeCKOoknOY

# OneLink Reviews — Supabase config
# Copy this file to `.env.local` (local dev) and add the same vars to
# your Vercel project (Settings → Environment Variables) for production.
#
# Without these, the /reviews page renders an empty state and POSTs
# return 503 — but the rest of the app keeps working.
#
# DATABASE SETUP: open `supabase/reviews.sql` in this repo, paste the
# entire file into the Supabase SQL Editor, and Run once. It creates the
# table, RLS policies, the UNIQUE device_key constraint that powers
# "one review per device", and (optionally) demo rows.
# =====================================================================

SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# RECOMMENDED for production: server-only service role JWT — bypasses RLS
# so duplicate-device lookups always succeed even if a row is unapproved.
# Get it from Supabase → Settings → API → "service_role" (NOT the anon key).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Fallback (local dev only): anon JWT works as long as the RLS policies
# in supabase/reviews.sql are applied. The service role key takes
# precedence if both are set.
# SUPABASE_ANON_KEY=eyJhbGciOi...
